#include <stdio.h>
int main() {
int y, *p, x; // y e x são indefinidos; p: ponteiro nulo 
y = 0; // y agora vale 0
    // y = 0, p: nulo, x: indefinido 
p = &y; // p aponta para y (guarda endereço de y) 
    // y = 0, p = &y, x: indefinido 
x = *p; //x recebe o valor que o ponteiro p está apontando (isto é y=0)
    // y = 0, p = &y e x=0 
x = 4; //x recebe 4
    // y = 0; x=4; p=&y 
++(*p); // incrementa o valor que p está apontando em 1; (*p) = (*p) + 1; ou seja y++
    // y = 1, x=4, p=&y
x--; // irá fazer x = x - 1
    // y = 1, x = 3, p = &y 
(*p) += x++; // irá fazer duas contas diferentes:
// 1. (*p) += x, ou seja (*p) = (*p) + x = y + x = 1 + 3 = 4 
// 2. x++, ou seja x = x + 1 = 3 + 1 = 4
    // y = 4, x = 4, p = &y 
printf ("y = %d\n", y);
//o valor final de y será 4. 

return 0;
} 
